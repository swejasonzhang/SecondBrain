# --- Database (Neon Postgres with pgvector) ---
# Create a free serverless Postgres at https://neon.tech and paste the connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Anthropic (Claude) — text generation for RAG chat + enrichment ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key"

# --- Voyage AI — embeddings for semantic search ---
# Anthropic's recommended embeddings partner. Get a key at https://dash.voyageai.com
VOYAGE_API_KEY="your-voyage-api-key"

# --- Clerk — authentication & per-user data isolation ---
# Create a free app at https://dashboard.clerk.com and copy both keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"
